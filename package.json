{
  "name": "lms-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:kill-ports": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/kill-dev-ports.ps1",
    "dev:clear-web-lock": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (Test-Path 'apps/web-client/.next/dev/lock') { Remove-Item 'apps/web-client/.next/dev/lock' -Force }\"",
    "dev": "pnpm dev:kill-ports && pnpm dev:clear-web-lock && turbo run dev --concurrency=20",
    "dev:web": "pnpm dev:kill-ports && pnpm dev:clear-web-lock && turbo run dev --concurrency=12 --filter web-client --filter @lms/auth-service --filter @lms/course-service --filter @lms/instructor-service --filter @lms/media-service --filter @lms/env-validator --filter @lms/logger --filter @lms/types --filter @lms/kafka-client",
    "dev:web:lite": "pnpm dev:kill-ports && pnpm dev:clear-web-lock && turbo run dev --concurrency=10 --filter web-client --filter @lms/auth-service --filter @lms/course-service --filter @lms/env-validator --filter @lms/logger --filter @lms/types --filter @lms/kafka-client",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:integration": "vitest run",
    "lint": "turbo run lint",
    "prisma:generate:all": "pnpm -r --workspace-concurrency=1 --filter ./services/* run prisma:generate",
    "prisma:migrate:deploy:all": "pnpm -r --workspace-concurrency=1 --filter ./services/* exec prisma migrate deploy",
    "prisma:migrate:status:all": "pnpm -r --workspace-concurrency=1 --filter ./services/* exec prisma migrate status",
    "prisma:push:all": "pnpm -r --workspace-concurrency=1 --filter ./services/* run prisma:push",
    "setup": "pnpm install && pnpm docker:up && pnpm setup:db && pnpm seed",
    "setup:db": "pnpm prisma:migrate:deploy:all && pnpm prisma:generate:all",
    "db:sync": "pnpm prisma:push:all && pnpm prisma:generate:all",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:health": "docker-compose ps",
    "seed": "pnpm --filter @lms/auth-service exec npx tsx ../../scripts/seed-all.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "bcryptjs": "^2.4.3",
    "ioredis": "^5.10.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}

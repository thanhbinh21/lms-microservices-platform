{
  "name": "lms-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:kill-ports": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/kill-dev-ports.ps1",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:integration": "vitest run",
    "lint": "turbo run lint",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:health": "docker-compose ps",
    "seed": "pnpm --filter @lms/auth-service exec npx tsx ../../scripts/seed-all.ts",
    "seed:accounts": "pnpm --filter @lms/auth-service exec npx tsx ../../scripts/seed-accounts.ts",
    "seed:courses": "pnpm --filter @lms/auth-service exec npx tsx ../../scripts/seed-courses.ts"
  },
  "devDependencies": {
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}

# Shared
KAFKA_BROKER=localhost:9092
# Upstash Redis over TLS for auth session storage
REDIS_URL=rediss://default:PASSWORD@UPSTASH_HOST:6379
INTERNAL_SERVICE_SECRET=change-this-shared-internal-secret

# DB per service (pooled URL for runtime, direct URL for Prisma migrate)
DATABASE_URL_AUTH=postgresql://USER:PASSWORD@AUTH_HOST-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15&connection_limit=10&pool_timeout=15&pgbouncer=true
DIRECT_URL_AUTH=postgresql://USER:PASSWORD@AUTH_HOST.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30
DATABASE_URL_COURSE=postgresql://USER:PASSWORD@COURSE_HOST-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15&connection_limit=10&pool_timeout=15&pgbouncer=true
DIRECT_URL_COURSE=postgresql://USER:PASSWORD@COURSE_HOST.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30
DATABASE_URL_LEARNING=postgresql://USER:PASSWORD@LEARNING_HOST-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15&connection_limit=10&pool_timeout=15&pgbouncer=true
DIRECT_URL_LEARNING=postgresql://USER:PASSWORD@LEARNING_HOST.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30
DATABASE_URL_COMMUNITY=postgresql://USER:PASSWORD@COMMUNITY_HOST-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15&connection_limit=10&pool_timeout=15&pgbouncer=true
DIRECT_URL_COMMUNITY=postgresql://USER:PASSWORD@COMMUNITY_HOST.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30
DATABASE_URL_PAYMENT=postgresql://USER:PASSWORD@PAYMENT_HOST-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15&connection_limit=10&pool_timeout=15&pgbouncer=true
DIRECT_URL_PAYMENT=postgresql://USER:PASSWORD@PAYMENT_HOST.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30
DATABASE_URL_MEDIA=postgresql://USER:PASSWORD@MEDIA_HOST-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15&connection_limit=10&pool_timeout=15&pgbouncer=true
DIRECT_URL_MEDIA=postgresql://USER:PASSWORD@MEDIA_HOST.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30
DATABASE_URL_NOTIFICATION=postgresql://USER:PASSWORD@NOTIFICATION_HOST-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15&connection_limit=10&pool_timeout=15&pgbouncer=true
DIRECT_URL_NOTIFICATION=postgresql://USER:PASSWORD@NOTIFICATION_HOST.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30

# App
NODE_ENV=development
LOG_LEVEL=debug

# LMS Platform - Environment Configuration (Root)
#
# NOTE: Database URLs duoc cau hinh PER SERVICE trong .env rieng cua tung service
# (pattern Database-per-Service). Vi du: services/payment-service/.env -> DATABASE_URL.
# File nay chi chua bien dung chung toan he thong + placeholder cho payment (Phase 13-16).

# ─── Ha tang dung chung ──────────────────────────────────────────────────────
KAFKA_BROKER=localhost:9092
REDIS_URL=redis://localhost:6379

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
JWT_SECRET=change_me_to_a_random_string_of_at_least_32_characters

# ─── Instructor Service (cho docker-compose neu can) ─────────────────────────
DATABASE_URL_INSTRUCTOR=postgresql://user:password@host/database?sslmode=require&channel_binding=require

# ─── Notification Service (Phase 11) ─────────────────────────────────────────
# Database-per-service: gia tri thuc dat trong services/notification-service/.env
# notification_db luu bang notifications (in-app bell + audit email sent).

# ─── VNPay (sandbox) — Phase 13-14 ────────────────────────────────────────────
# Gia tri thuc se duoc copy vao services/payment-service/.env
VNPAY_TMN_CODE=0AGF6VZ4
VNPAY_HASH_SECRET=VXQECSIQQ5L9Z6KET3A95RNYSMRZ4FDV
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# Trang frontend hien thi ket qua sau khi VNPay redirect user ve.
VNPAY_RETURN_URL=http://localhost:3000/payment/vnpay-return
# Webhook S2S VNPay goi khi giao dich xong.
# LUU Y: VNPay sandbox KHONG goi duoc localhost -> khi test IPN that can ngrok
# (vd: https://xxx.ngrok.app/payment/api/vnpay-ipn).
VNPAY_IPN_URL=http://localhost:8000/payment/api/vnpay-ipn

# ─── Payment metadata ────────────────────────────────────────────────────────
PAYMENT_CURRENCY=VND
PAYMENT_TIMEOUT=15
PAYMENT_VERSION=2.1.0
PAYMENT_COMMAND=pay
PAYMENT_LOCALE=vn
PAYMENT_ORDER_TYPE=other

# ─── Web Client (Next.js) ────────────────────────────────────────────────────
# GATEWAY_URL: URL Kong duoc web-client goi (server actions).
# NEXT_PUBLIC_*: expose ra browser.
# GATEWAY_URL=http://localhost:8000
# NEXT_PUBLIC_AUTH_PREFIX=/auth
# NEXT_PUBLIC_PAYMENT_PREFIX=/payment

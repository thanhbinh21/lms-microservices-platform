{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env"],
  "concurrency": "15",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "prisma:generate": {
      "cache": true,
      "outputs": ["node_modules/@prisma/client/**", "src/generated/client/**"]
    }
  }
}

PORT=3006
NODE_ENV=development
LOG_LEVEL=info

# learning_db — Tao Neon project rieng cho service nay
# Vi du: https://console.neon.tech/ -> New Project -> learning_db
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require&pgbouncer=true
DIRECT_URL=postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Kafka
KAFKA_BROKER=localhost:9092

# Internal service URLs (khong qua Kong)
COURSE_SERVICE_URL=http://localhost:3002
INTERNAL_SERVICE_SECRET=change-this-shared-internal-secret

# CORS
CORS_ORIGIN=http://localhost:3000

PORT=3005
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

DATABASE_URL=postgresql://USER:PASSWORD@NOTIFICATION_HOST-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15&connection_limit=10&pool_timeout=15&pgbouncer=true
DIRECT_URL=postgresql://USER:PASSWORD@NOTIFICATION_HOST.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30

KAFKA_BROKER=localhost:9092
KAFKA_CLIENT_ID=notification-service
INTERNAL_SERVICE_SECRET=change-this-shared-internal-secret
AUTH_SERVICE_URL=http://localhost:3101

# SMTP provider
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=replace-with-smtp-user
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=LMS Platform <noreply@example.com>

# Demo retry email, luon de 0 tren production.
DEMO_NOTIFICATION_FAIL_ATTEMPTS=0

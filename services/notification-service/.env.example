PORT=3005
NODE_ENV=development
LOG_LEVEL=info

# CORS (cho phep goi truc tiep tu web-client trong dev; prod nen di qua Kong)
CORS_ORIGIN=http://localhost:3000

# ─── Neon PostgreSQL (notification_db) ───────────────────────────────────────
# Tao database "notification_db" tren Neon roi dan connection string vao day.
# Pooler URL — dung cho runtime queries.
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.neon.tech/notification_db?sslmode=require"
# Direct URL — dung cho prisma migrate/db push.
DIRECT_URL="postgresql://user:pass@ep-xxx.neon.tech/notification_db?sslmode=require"

# ─── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BROKER=localhost:9092
KAFKA_CLIENT_ID=notification-service

# ─── Email (Phase 11 — hien tai chi log mock email ra console) ───────────────
# Sau nay Phase 11 se dung Nodemailer (dev) + Resend (prod).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=True
SMTP_PASS=xuxobkqfbjukgmto
EMAIL_FROM=tranthitrinh4013@gmail.com

// Prisma Schema for Payment Service
// Database: payment_db (Neon Serverless PostgreSQL)

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-v2"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  COMPLETED
  FAILED
  EXPIRED
  REFUNDED
}

enum PaymentMethod {
  VNPAY
}

enum AuditKind {
  CREATE_URL
  RETURN
  IPN
}

enum EarningStatus {
  PENDING
  AVAILABLE
  WITHDRAWN
}

enum PayoutStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

// ─── Models ───────────────────────────────────────────────────────────────────

/// Don hang tao boi user khi mua khoa hoc.
/// vnpTxnRef la idempotency key phia VNPay (dung lam ma giao dich trong URL thanh toan).
model Order {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  courseId      String        @map("course_id")
  instructorId  String        @map("instructor_id")
  courseTitle   String?       @map("course_title")
  amount        Decimal       @db.Decimal(12, 2)
  currency      String        @default("VND")
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod @default(VNPAY) @map("payment_method")

  vnpTxnRef         String  @unique @map("vnp_txn_ref")
  vnpPayUrl         String? @map("vnp_pay_url") @db.Text
  vnpTransactionNo  String? @map("vnp_transaction_no")
  vnpBankCode       String? @map("vnp_bank_code")
  vnpResponseCode   String? @map("vnp_response_code")
  failureReason     String? @map("failure_reason")

  paidAt    DateTime? @map("paid_at")
  expiresAt DateTime? @map("expires_at")
  traceId   String?   @map("trace_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  audits VNPayAudit[]

  @@index([userId])
  @@index([courseId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("orders")
}

/// Luu toan bo payload VNPay duoi dang JSONB phuc vu audit/compliance.
model VNPayAudit {
  id        String    @id @default(uuid())
  orderId   String    @map("order_id")
  kind      AuditKind
  payload   Json      @db.JsonB
  signature String?   @db.Text
  valid     Boolean   @default(false)
  note      String?
  createdAt DateTime  @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([kind])
  @@map("vnpay_audits")
}

/// Thu nhap cua giang vien tu moi order thanh cong.
/// Payment consumer tao record khi nhan payment.order.completed.
model InstructorEarning {
  id           String        @id @default(uuid())
  orderId     String        @unique @map("order_id")
  instructorId String        @map("instructor_id")
  courseId    String        @map("course_id")
  grossAmount Decimal        @db.Decimal(12, 2) @map("gross_amount")
  platformFee Decimal        @db.Decimal(12, 2) @default(0.30) @map("platform_fee")
  revenueSharePct Decimal    @db.Decimal(5, 4) @default(0.7000) @map("revenue_share_pct")
  platformFeePct  Decimal    @db.Decimal(5, 4) @default(0.3000) @map("platform_fee_pct")
  netAmount   Decimal       @db.Decimal(12, 2) @map("net_amount")
  status      EarningStatus @default(PENDING)
  createdAt   DateTime      @default(now()) @map("created_at")

  @@index([instructorId])
  @@index([courseId])
  @@map("instructor_earnings")
}

/// Ho so thanh toan cua giang vien de phuc vu payout.
model InstructorPayoutProfile {
  id               String   @id @default(uuid())
  instructorId     String   @unique @map("instructor_id")
  bankName         String   @map("bank_name")
  bankAccount      String   @map("bank_account")
  bankAccountMasked String  @map("bank_account_masked")
  accountHolder    String   @map("account_holder")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([updatedAt(sort: Desc)])
  @@map("instructor_payout_profiles")
}

/// Yeu cau rut tien cua giang vien cho admin duyet.
model Payout {
  id                 String       @id @default(uuid())
  instructorId       String       @map("instructor_id")
  amount             Decimal      @db.Decimal(12, 2)
  bankAccountMasked  String       @map("bank_account_masked")
  status             PayoutStatus @default(PENDING)
  adminNote          String?      @map("admin_note")
  processedAt        DateTime?    @map("processed_at")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  @@index([instructorId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("payouts")
}

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3003
NODE_ENV=development
LOG_LEVEL=info

# CORS (cho phep goi truc tiep tu web-client trong dev neu can; prod nen di qua Kong)
CORS_ORIGIN=http://localhost:3000

# ─── Neon PostgreSQL (payment_db) ────────────────────────────────────────────
# Tao database "payment_db" tren Neon roi dan connection string vao day.
# Pooler URL - dung cho runtime queries
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.neon.tech/payment_db?sslmode=require"
# Direct URL - dung cho prisma migrate/db push
DIRECT_URL="postgresql://user:pass@ep-xxx.neon.tech/payment_db?sslmode=require"

# ─── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BROKER=localhost:9092
KAFKA_CLIENT_ID=payment-service

# ─── Internal service discovery ──────────────────────────────────────────────
# Payment-service goi Course-service noi bo de verify price (chong tampering).
# Tuong duong URL truc tiep den container/process course-service (khong qua Kong).
COURSE_SERVICE_URL=http://localhost:3002

# ─── VNPay (sandbox) ─────────────────────────────────────────────────────────
VNPAY_TMN_CODE=0AGF6VZ4
VNPAY_HASH_SECRET=VXQECSIQQ5L9Z6KET3A95RNYSMRZ4FDV
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# URL user duoc redirect ve sau khi thanh toan (frontend).
VNPAY_RETURN_URL=http://localhost:3000/payment/vnpay-return
# URL webhook server-to-server VNPay goi khi giao dich hoan tat.
# LUU Y: VNPay sandbox KHONG goi duoc localhost — khi test IPN that can ngrok
# (vd: https://xxx.ngrok.app/payment/api/vnpay-ipn) roi cap nhat vao day.
VNPAY_IPN_URL=http://localhost:8000/payment/api/vnpay-ipn

# ─── Payment config ──────────────────────────────────────────────────────────
PAYMENT_CURRENCY=VND
PAYMENT_TIMEOUT=15
PAYMENT_VERSION=2.1.0
PAYMENT_COMMAND=pay
PAYMENT_LOCALE=vn
PAYMENT_ORDER_TYPE=other

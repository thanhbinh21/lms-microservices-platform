{
  "name": "@lms/course-service",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "node ../../scripts/prisma-postinstall.cjs",
    "dev": "tsx watch src/index.ts",
    "dev:transcript-worker": "tsx watch src/workers/transcript.worker.ts",
    "build": "tsc && node ../../scripts/prisma-postinstall.cjs --copy-to-dist",
    "start": "node dist/index.js",
    "start:transcript-worker": "node dist/workers/transcript.worker.js",
    "transcript:backfill": "cross-env NODE_ENV=production tsx src/scripts/backfill-ai-context.ts",
    "ai-context:backfill": "cross-env NODE_ENV=production tsx src/scripts/backfill-ai-context.ts",
    "read-model:warmup": "tsx src/scripts/warmup-course-read-model.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "node ../../scripts/prisma-migrate-retry.js",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@lms/cache": "workspace:*",
    "@lms/db-prisma": "workspace:*",
    "@lms/kafka-client": "workspace:*",
    "@lms/logger": "workspace:*",
    "@lms/types": "workspace:*",
    "@lms/env-validator": "workspace:*",
    "@prisma/client": "^6.6.0",
    "express": "^4.21.2",
    "zod": "^3.22.4",
    "cors": "^2.8.5",
    "helmet": "^8.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.6",
    "prisma": "^6.6.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.2"
  }
}

PORT=3002
NODE_ENV=development
LOG_LEVEL=info

DATABASE_URL=postgresql://USER:PASSWORD@COURSE_HOST-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15&connection_limit=10&pool_timeout=15&pgbouncer=true
DIRECT_URL=postgresql://USER:PASSWORD@COURSE_HOST.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30

KAFKA_BROKER=localhost:9092
CACHE_REDIS_URL=rediss://default:PASSWORD@UPSTASH_HOST:6379

# Internal learning-service URL (khong qua Kong)
LEARNING_SERVICE_URL=http://localhost:3006
AUTH_SERVICE_URL=http://localhost:3101
INTERNAL_SERVICE_SECRET=change-this-shared-internal-secret

CORS_ORIGIN=http://localhost:3000

# AI context pipeline
# Mac dinh khong xu ly audio/video de tranh ton quota STT.
# AI chat/quiz dung AUTO_CONTEXT tao tu title, mo ta, chapter, lesson content va tu khoa.
TRANSCRIPT_AUTO_STT_ENABLED=false
TRANSCRIPT_WORKER_ENABLED=false
TRANSCRIPT_STT_PROVIDER=disabled
TRANSCRIPT_STT_LANGUAGE=vi
TRANSCRIPT_GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=
# Deepgram xu ly remote MP4/Cloudinary URL rat don gian: POST { "url": videoUrl }
DEEPGRAM_API_KEY=
TRANSCRIPT_DEEPGRAM_MODEL=nova-3
# OpenAI can download file ve service roi upload multipart, chi nen dung file nho.
OPENAI_API_KEY=
TRANSCRIPT_OPENAI_MODEL=gpt-4o-mini-transcribe
TRANSCRIPT_OPENAI_MAX_DOWNLOAD_MB=25
# Local fallback tuy chon neu may co cai san FFmpeg/Python/faster-whisper.
FASTER_WHISPER_MODEL=small
PYTHON_PATH=python
FFMPEG_PATH=ffmpeg
YT_DLP_PATH=yt-dlp
TRANSCRIPT_JOB_POLL_MS=10000
TRANSCRIPT_JOB_MAX_ATTEMPTS=3
# Demo fault isolation, luon de false tren production.
FAULT_INJECTION_ENABLED=false
COURSE_FAULT_DELAY_MS=0
INTERNAL_HTTP_TIMEOUT_MS=2000

// Prisma Schema for Course Service
// Database: course_db (Neon Serverless PostgreSQL)

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-v2"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum LessonSourceType {
  UPLOAD
  YOUTUBE
}

enum FailedEventStatus {
  PENDING
  RETRIED
  RESOLVED
  IGNORED
}


// ─── Models ───────────────────────────────────────────────────────────────────

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  courses Course[]

  @@map("categories")
}

model Course {
  id              String       @id @default(uuid())
  title           String
  slug            String       @unique
  description     String?
  thumbnail       String?
  price           Decimal      @default(0) @db.Decimal(10, 2)
  level           CourseLevel  @default(BEGINNER)
  status          CourseStatus @default(DRAFT)
  categoryId      String?      @map("category_id")
  instructorId    String       @map("instructor_id")
  totalLessons    Int          @default(0) @map("total_lessons")
  totalDuration   Int          @default(0) @map("total_duration")
  averageRating   Float        @default(0) @map("average_rating")
  ratingCount     Int          @default(0) @map("rating_count")
  enrollmentCount Int          @default(0) @map("enrollment_count")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  category    Category?    @relation(fields: [categoryId], references: [id])
  chapters    Chapter[]
  reviews     Review[]
  certificateTemplates CourseCertificateTemplate[]
  enrollmentSignals EnrollmentSignal[]

  @@index([instructorId])
  @@index([status])
  @@index([categoryId])
  @@index([averageRating(sort: Desc), enrollmentCount(sort: Desc)])
  @@index([price])
  @@index([createdAt(sort: Desc)])
  // Composite indexes cho discovery queries (luon filter status truoc)
  @@index([status, categoryId])
  @@index([status, level])
  @@index([status, createdAt(sort: Desc)])
  @@map("courses")
}

model Chapter {
  id          String   @id @default(uuid())
  title       String
  order       Int      @default(0)
  isPublished Boolean  @default(false) @map("is_published")
  courseId    String   @map("course_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
  @@map("chapters")
}

model Lesson {
  id          String   @id @default(uuid())
  title       String
  order       Int      @default(0)
  videoUrl    String?  @map("video_url")   // VideoCipher/S3 (Phase 6)
  sourceType  LessonSourceType @default(UPLOAD) @map("source_type")
  content     String?  // Noi dung/mo ta bai hoc (text)
  duration    Int      @default(0)          // seconds
  isPublished Boolean  @default(false) @map("is_published")
  isFree      Boolean  @default(false) @map("is_free") // preview lesson
  chapterId   String   @map("chapter_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@map("lessons")
}

// Enrollment signals tu learning-service (idempotent theo orderId)
model EnrollmentSignal {
  id        String   @id @default(uuid())
  orderId   String   @unique @map("order_id")
  userId    String   @map("user_id")
  courseId  String   @map("course_id")
  createdAt DateTime @default(now()) @map("created_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([userId])
  @@map("enrollment_signals")
}

model CertificateTemplate {
  id          String   @id @default(uuid())
  instructorId String  @map("instructor_id")
  name        String
  description String?  @map("description")
  previewUrl  String?  @map("preview_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  courseLinks CourseCertificateTemplate[]

  @@index([instructorId])
  @@map("certificate_templates")
}

model CourseCertificateTemplate {
  id         String   @id @default(uuid())
  courseId   String   @map("course_id")
  templateId String   @map("template_id")
  createdAt  DateTime @default(now()) @map("created_at")

  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  template CertificateTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([courseId, templateId])
  @@index([templateId])
  @@map("course_certificate_templates")
}

model Review {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  courseId  String   @map("course_id")
  rating    Int      // 1-5
  comment   String?
  isFlagged Boolean  @default(false) @map("is_flagged")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
  @@index([isFlagged])
  @@map("reviews")
}

model FailedEvent {
  id           String            @id @default(uuid())
  topic        String
  originalKey  String?           @map("original_key")
  payload      Json
  errorMessage String            @map("error_message")
  retryCount   Int               @default(0) @map("retry_count")
  status       FailedEventStatus @default(PENDING)
  createdAt    DateTime          @default(now()) @map("created_at")
  retriedAt    DateTime?         @map("retried_at")

  @@index([status])
  @@index([topic])
  @@map("failed_events")
}

/// Hồ sơ công khai của giảng viên — tạo tự động khi user nâng cấp lên INSTRUCTOR.
model InstructorProfile {
  id           String   @id @default(uuid())
  instructorId String   @unique @map("instructor_id")
  slug         String   @unique
  displayName  String   @map("display_name")
  headline     String?  // Dòng giới thiệu ngắn (1-2 câu)
  bio          String?  // Mô tả đầy đủ
  avatar       String?  // URL ảnh đại diện
  socialLinks  Json     @default("{}") @map("social_links") // { website, facebook, youtube, twitter, linkedin }
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@map("instructor_profiles")
}


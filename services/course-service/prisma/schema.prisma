// Prisma Schema for Course Service
// Database: course_db (Neon Serverless PostgreSQL)

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum LessonSourceType {
  UPLOAD
  YOUTUBE
}

enum FailedEventStatus {
  PENDING
  RETRIED
  RESOLVED
  IGNORED
}

enum CommunityGroupType {
  PUBLIC
  COURSE_PRIVATE
}


// ─── Models ───────────────────────────────────────────────────────────────────

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  courses Course[]

  @@map("categories")
}

model Course {
  id              String       @id @default(uuid())
  title           String
  slug            String       @unique
  description     String?
  thumbnail       String?
  price           Decimal      @default(0) @db.Decimal(10, 2)
  level           CourseLevel  @default(BEGINNER)
  status          CourseStatus @default(DRAFT)
  categoryId      String?      @map("category_id")
  instructorId    String       @map("instructor_id")
  totalLessons    Int          @default(0) @map("total_lessons")
  totalDuration   Int          @default(0) @map("total_duration")
  averageRating   Float        @default(0) @map("average_rating")
  ratingCount     Int          @default(0) @map("rating_count")
  enrollmentCount Int          @default(0) @map("enrollment_count")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  category    Category?    @relation(fields: [categoryId], references: [id])
  chapters    Chapter[]
  enrollments Enrollment[]
  reviews     Review[]
  certificates Certificate[]
  communityGroups CommunityGroup[]

  @@index([instructorId])
  @@index([status])
  @@index([categoryId])
  @@index([averageRating(sort: Desc), enrollmentCount(sort: Desc)])
  @@index([price])
  @@index([createdAt(sort: Desc)])
  // Composite indexes cho discovery queries (luon filter status truoc)
  @@index([status, categoryId])
  @@index([status, level])
  @@index([status, createdAt(sort: Desc)])
  @@map("courses")
}

model Chapter {
  id          String   @id @default(uuid())
  title       String
  order       Int      @default(0)
  isPublished Boolean  @default(false) @map("is_published")
  courseId    String   @map("course_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
  @@map("chapters")
}

model Lesson {
  id          String   @id @default(uuid())
  title       String
  order       Int      @default(0)
  videoUrl    String?  @map("video_url")   // VideoCipher/S3 (Phase 6)
  sourceType  LessonSourceType @default(UPLOAD) @map("source_type")
  content     String?  // Noi dung/mo ta bai hoc (text)
  duration    Int      @default(0)          // seconds
  isPublished Boolean  @default(false) @map("is_published")
  isFree      Boolean  @default(false) @map("is_free") // preview lesson
  chapterId   String   @map("chapter_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  progress LessonProgress[] // 1 Lesson co nhieu tien do cua hoc vien

  @@index([chapterId])
  @@map("lessons")
}

// Luu vet tien do hoc tap cua hoc vien tren tung bai hoc
model LessonProgress {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")      // User dang ky
  lessonId    String   @map("lesson_id")
  isCompleted Boolean  @default(false) @map("is_completed")
  lastWatched Int      @default(0) @map("last_watched") // so giay (thoi luong da xem)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId]) // 1 user chi co 1 progress / lesson
  @@index([userId])
  @@map("lesson_progress")
}

// Enrollment — owned by Course Service (source of truth for access control)
// Populated by Kafka consumer in Phase 12 or by direct Free Enroll
model Enrollment {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")      // from Kafka event
  courseId   String   @map("course_id")
  orderId    String   @unique @map("order_id") // idempotency key hoac dummy_order
  enrolledAt DateTime @default(now()) @map("enrolled_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  certificates Certificate[]

  @@unique([userId, courseId])
  @@index([userId])
  @@map("enrollments")
}

model Certificate {
  id                String   @id @default(uuid())
  certificateNumber String   @unique @map("certificate_number")
  userId            String   @map("user_id")
  courseId          String   @map("course_id")
  enrollmentId      String   @map("enrollment_id")
  issuedAt          DateTime @default(now()) @map("issued_at")
  completedAt       DateTime @map("completed_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  course      Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollment  Enrollment  @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId, issuedAt(sort: Desc)])
  @@index([courseId])
  @@map("certificates")
}

model Review {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  courseId  String   @map("course_id")
  rating    Int      // 1-5
  comment   String?
  isFlagged Boolean  @default(false) @map("is_flagged")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
  @@index([isFlagged])
  @@map("reviews")
}

model CommunityGroup {
  id          String             @id @default(uuid())
  type        CommunityGroupType @default(COURSE_PRIVATE)
  courseId    String?            @map("course_id")
  ownerId     String             @map("owner_id")
  name        String
  slug        String             @unique
  description String?
  memberCount Int                @default(0) @map("member_count")
  postCount   Int                @default(0) @map("post_count")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  course   Course?           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  members  CommunityMember[]
  posts    CommunityPost[]

  // Moi khoa hoc chi co toi da 1 private group
  @@unique([courseId], map: "community_groups_course_id_unique")
  @@index([type])
  @@index([ownerId])
  @@index([createdAt(sort: Desc)])
  @@map("community_groups")
}

model CommunityMember {
  id        String   @id @default(uuid())
  groupId   String   @map("group_id")
  userId    String   @map("user_id")
  joinedAt  DateTime @default(now()) @map("joined_at")
  createdAt DateTime @default(now()) @map("created_at")

  group CommunityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
  @@index([groupId])
  @@map("community_members")
}

model CommunityPost {
  id        String   @id @default(uuid())
  groupId   String   @map("group_id")
  authorId  String   @map("author_id")
  parentId  String?  @map("parent_id")
  content      String
  imageUrl     String?  @map("image_url")
  likeCount    Int      @default(0) @map("like_count")
  likedByIds   String[] @default([]) @map("liked_by_ids")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  group   CommunityGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  parent  CommunityPost?  @relation("CommunityPostReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies CommunityPost[] @relation("CommunityPostReplies")

  @@index([groupId, createdAt(sort: Desc)])
  @@index([parentId])
  @@index([authorId])
  @@map("community_posts")
}

model FailedEvent {
  id           String            @id @default(uuid())
  topic        String
  originalKey  String?           @map("original_key")
  payload      Json
  errorMessage String            @map("error_message")
  retryCount   Int               @default(0) @map("retry_count")
  status       FailedEventStatus @default(PENDING)
  createdAt    DateTime          @default(now()) @map("created_at")
  retriedAt    DateTime?         @map("retried_at")

  @@index([status])
  @@index([topic])
  @@map("failed_events")
}


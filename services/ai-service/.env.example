# AI Service Environment Variables
# Copy this file to .env and fill in the values

# Service
PORT=3008
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Database (Neon Serverless PostgreSQL)
DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/ai_db?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxx.neon.tech/ai_db?sslmode=require"

# Redis / Upstash
REDIS_URL="rediss://default:PASSWORD@UPSTASH_HOST:6379"
CACHE_REDIS_URL="rediss://default:PASSWORD@UPSTASH_HOST:6379"

# Gemini AI
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_MODEL="gemini-2.0-flash"
GEMINI_FALLBACK_MODEL="gemini-2.0-flash-lite"

# Internal Service Auth
INTERNAL_SERVICE_SECRET="your-internal-service-secret-here"

# Cross-service URLs (for calling other services)
COURSE_SERVICE_URL="http://localhost:3002"
LEARNING_SERVICE_URL="http://localhost:3006"
AUTH_SERVICE_URL="http://localhost:3101"

# AI Service Environment Variables
# Copy this file to .env and fill in the values

# Service
PORT=3008
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Database (Neon Serverless PostgreSQL)
DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/ai_db?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxx.neon.tech/ai_db?sslmode=require"

# Redis / Upstash
REDIS_URL="rediss://default:PASSWORD@UPSTASH_HOST:6379"
CACHE_REDIS_URL="rediss://default:PASSWORD@UPSTASH_HOST:6379"

# LLM Providers. Local demo keeps OpenRouter before empty-balance providers.
AI_PROVIDER_ORDER="groq,openrouter,deepseek"

DEEPSEEK_API_KEY="your-deepseek-api-key-here"
DEEPSEEK_MODEL="deepseek-chat"

GROQ_API_KEY="your-groq-api-key-here"
GROQ_MODEL="llama-3.3-70b-versatile"

OPENROUTER_API_KEY="your-openrouter-api-key-here"
OPENROUTER_MODEL="openai/gpt-4o-mini"
OPENROUTER_APP_URL="http://localhost:3000"
OPENROUTER_APP_NAME="olms-ai-service"

AI_STRICT_CONTEXT_GATE=false
AI_DEMO_FALLBACK_QUIZ=false

# Internal Service Auth
INTERNAL_SERVICE_SECRET="your-internal-service-secret-here"

# Cross-service URLs (for calling other services)
COURSE_SERVICE_URL="http://localhost:3002"
LEARNING_SERVICE_URL="http://localhost:3006"
AUTH_SERVICE_URL="http://localhost:3101"

PORT=3007
NODE_ENV=development
LOG_LEVEL=info

# community_db — Tao Neon project rieng cho service nay
DATABASE_URL=postgresql://USER:PASSWORD@COMMUNITY_HOST-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15&connection_limit=10&pool_timeout=15&pgbouncer=true

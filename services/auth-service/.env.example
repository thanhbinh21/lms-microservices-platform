NODE_ENV=development
LOG_LEVEL=debug

DATABASE_URL=postgresql://USER:PASSWORD@AUTH_HOST-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15&connection_limit=10&pool_timeout=15&pgbouncer=true
DIRECT_URL=postgresql://USER:PASSWORD@AUTH_HOST.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30

# Upstash Redis over TLS for session storage
REDIS_URL=rediss://default:PASSWORD@UPSTASH_HOST:6379

# JWT_SECRET phai trung voi KONG_JWT_SECRET khi deploy public.
JWT_SECRET=replace-with-random-min-32-char-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
INTERNAL_SERVICE_SECRET=change-this-shared-internal-secret

PORT=3101

{
  "name": "@lms/auth-service",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "node ../../scripts/prisma-postinstall.cjs",
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node ../../scripts/prisma-postinstall.cjs --copy-to-dist",
    "start": "node dist/index.js",
    "test": "vitest run --exclude \"dist/**\"",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "node ../../scripts/prisma-migrate-retry.js",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@lms/db-prisma": "workspace:*",
    "@lms/env-validator": "workspace:*",
    "@lms/logger": "workspace:*",
    "@lms/types": "workspace:*",
    "@prisma/client": "^6.6.0",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "redis": "^4.6.12",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "prisma": "^6.6.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  }
}

PORT=3006
# Neon: https://console.neon.tech — tao project (hoac branch) moi, lay connection string dan vao day. Sau do: pnpm prisma:migrate hoac prisma migrate deploy
DATABASE_URL_INSTRUCTOR=postgresql://user:password@host/database?sslmode=require&channel_binding=require
# Trực tiếp tới auth-service (PATCH /users/role). Phải cùng port với auth đang chạy (thường 3101).
# Không dùng hostname auth-service trừ khi cả hai service cùng Docker network và có service tên đó.
# Dev local: http://localhost:3101 | Container gọi auth trên host: http://host.docker.internal:3101
AUTH_SERVICE_URL=http://localhost:3101
MEDIA_SERVICE_URL=http://localhost:3004
JWT_SECRET=change_me

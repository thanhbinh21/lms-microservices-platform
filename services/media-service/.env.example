PORT=3004
NODE_ENV=development
LOG_LEVEL=info
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/media_db?sslmode=require
DIRECT_URL=postgresql://user:pass@ep-xxx.neon.tech/media_db?sslmode=require
CORS_ORIGIN=http://localhost:3000

STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=./uploads

# Neu co CLOUDINARY_URL, media-service se uu tien Cloudinary va fallback local khi can.
# Dinh dang: cloudinary://<api_key>:<api_secret>@<cloud_name>
# CLOUDINARY_URL=cloudinary://1234567890:your_api_secret@your_cloud_name

# Optional when STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=ap-southeast-1
# S3_BUCKET=lms-media-bucket
# S3_PRESIGNED_EXPIRY=3600

PORT=3004
NODE_ENV=development
LOG_LEVEL=info
DATABASE_URL=postgresql://USER:PASSWORD@MEDIA_HOST-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15&connection_limit=10&pool_timeout=15&pgbouncer=true
DIRECT_URL=postgresql://USER:PASSWORD@MEDIA_HOST.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30
CORS_ORIGIN=http://localhost:3000
CACHE_REDIS_URL=rediss://default:PASSWORD@UPSTASH_HOST:6379
MEDIA_PUBLIC_BASE_URL=http://localhost:8000/media

STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=./uploads

# Neu co CLOUDINARY_URL, media-service se uu tien Cloudinary va fallback local khi can.
# Dinh dang: cloudinary://<api_key>:<api_secret>@<cloud_name>
# CLOUDINARY_URL=cloudinary://1234567890:your_api_secret@your_cloud_name

# Optional when STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=ap-southeast-1
# S3_BUCKET=lms-media-bucket
# S3_PRESIGNED_EXPIRY=3600
